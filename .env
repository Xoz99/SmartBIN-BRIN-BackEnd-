# ================================
# App
# ================================
# CATATAN MERGE: repo memakai 3000, backend-hardware (Downloads) memakai 3001.
# Pakai 3000 (default frontend). Ganti ke 3001 bila perangkat/proxy mengharapkan itu.
PORT=3000
NODE_ENV=development

# ================================
# Database (PostgreSQL)
# ================================
# CATATAN MERGE: repo lama "smartbin:password", backend-hardware "smartbin:smartbin123".
# Dipakai nilai dari backend-hardware (yang terakhir jalan). VERIFIKASI password Postgres lokal Anda.
DATABASE_URL="postgresql://smartbin:smartbin123@localhost:5432/smartbin_db?schema=public"

# ================================
# Redis
# ================================
REDIS_URL="redis://localhost:6379"

# ================================
# MQTT (HiveMQ Cloud — koneksi ke perangkat hardware)
# ================================
MQTT_BROKER_URL=mqtts://4b1ed76fd60640648c995b6c90f11829.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=bintrash
MQTT_PASSWORD=Smartbinbrin1
MQTT_CLIENT_ID="smartbin-backend"

# ================================
# Weight mode (pembacaan berat)
# ================================
# sensor_pairing = baca dari load-cell/IoT (mode hardware). Ganti bila perlu simulasi.
WEIGHT_MODE=sensor_pairing

# ================================
# JWT
# ================================
JWT_SECRET="db57f8f1b061af166a5f3bdfa3cc5f20b0a7d4ec9f0ebb7ac74e6e65d03a5f40e09cc537e6d42dcd6dd9a5ce495073d8c3ec8719abdae08035e91862e8e3751a"
JWT_EXPIRES_IN="7d"

# ================================
# Python Classify Microservice
# ================================
CLASSIFY_SERVICE_URL="http://localhost:8000"

# ================================
# CORS — URL frontend
# ================================
CORS_ORIGIN=https://brin-trash.vercel.app

# ================================
# Firebase FCM (push notifications)
# ================================
# Path ke file service-account JSON. Push otomatis nonaktif bila file tidak ada.
FIREBASE_CREDENTIALS_PATH="./firebase-credentials.json"

# ================================
# Thresholds (defaults, overridable per-bin)
# ================================
DEFAULT_WEIGHT_THRESHOLD=45
DEFAULT_VOLUME_THRESHOLD=85
DEFAULT_BATTERY_THRESHOLD=20
DEFAULT_GAS_THRESHOLD=300
