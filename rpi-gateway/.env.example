# ─── MQTT broker (server backend) ───────────────────────────────────────────
MQTT_BROKER_HOST=192.168.1.10
MQTT_BROKER_PORT=1883
MQTT_USERNAME=smartbin
MQTT_PASSWORD=replace-with-password-from-setup-mqtt-auth.sh

# ─── Gateway identity ───────────────────────────────────────────────────────
GATEWAY_ID=rpi-gateway-01
HEARTBEAT_INTERVAL_SEC=60

# ─── LoRa ───────────────────────────────────────────────────────────────────
# Driver: rfm9x (real hardware) or mock (test without LoRa module)
LORA_DRIVER=rfm9x
LORA_FREQ_MHZ=923.0

# ─── Camera (optional) ──────────────────────────────────────────────────────
# Leave CAMERA_NODE_ID empty to disable camera capture.
# If set, RPi captures an image every CAMERA_INTERVAL_SEC and publishes it
# under that node's image topic for backend YOLOv5 classification.
CAMERA_NODE_ID=
CAMERA_INTERVAL_SEC=300

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
