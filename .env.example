# ================================
# App
# ================================
PORT=3000
NODE_ENV=development

# ================================
# Database (PostgreSQL)
# ================================
DATABASE_URL="postgresql://smartbin:password@localhost:5432/smartbin_db?schema=public"

# ================================
# Redis
# ================================
REDIS_URL="redis://localhost:6379"

# ================================
# MQTT (Mosquitto)
# ================================
MQTT_BROKER_URL="mqtt://localhost:1883"
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_CLIENT_ID="smartbin-backend"

# ================================
# JWT
# ================================
JWT_SECRET="replace-with-a-very-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# ================================
# Python Classify Microservice
# ================================
CLASSIFY_SERVICE_URL="http://localhost:8000"

# ================================
# Firebase FCM (push notifications)
# ================================
# Path to your Firebase service account JSON file
FIREBASE_CREDENTIALS_PATH="./firebase-credentials.json"

# ================================
# Thresholds (defaults, overridable per-bin)
# ================================
DEFAULT_WEIGHT_THRESHOLD=45
DEFAULT_VOLUME_THRESHOLD=85
DEFAULT_BATTERY_THRESHOLD=20
