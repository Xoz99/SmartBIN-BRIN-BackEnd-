// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Bin — represents a physical smart bin
// ─────────────────────────────────────────────
model Bin {
  id        String   @id @default(cuid())
  nodeId    String   @unique // ESP32 node identifier (e.g. "bin-001")
  location  String // Human readable location name
  lat       Float // GPS latitude
  lng       Float // GPS longitude
  createdAt DateTime @default(now())

  // Per-bin alert thresholds (null = fall back to env defaults)
  weightThreshold  Float?
  volumeThreshold  Float?
  gasThreshold     Float?
  batteryThreshold Float?

  // Relationships
  areaId String? // Optional initially to not break existing data immediately
  area   Area?   @relation(fields: [areaId], references: [id])

  sensorLogs      SensorLog[]
  alerts          Alert[]
  classifications Classification[]
  pickups         Pickup[]

  @@map("bins")
}

// ─────────────────────────────────────────────
// SensorLog — time-series data from sensors
// ─────────────────────────────────────────────
model SensorLog {
  id    String @id @default(cuid())
  binId String
  bin   Bin    @relation(fields: [binId], references: [id], onDelete: Cascade)

  weight  Float // kg
  volume  Float // percentage 0–100
  battery Float // percentage 0–100
  gas     Float? // ppm — gas sensor reading (MQ-x)
  rssi    Int // dBm signal strength

  createdAt DateTime @default(now())

  @@index([binId])
  @@index([createdAt])
  @@map("sensor_logs")
}

// ─────────────────────────────────────────────
// Alert — threshold breach notifications
// ─────────────────────────────────────────────
enum AlertType {
  FULL_WEIGHT
  FULL_VOLUME
  BATTERY_LOW
  GAS_HIGH
}

model Alert {
  id    String @id @default(cuid())
  binId String
  bin   Bin    @relation(fields: [binId], references: [id], onDelete: Cascade)

  type     AlertType
  message  String
  resolved Boolean   @default(false)

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([binId])
  @@index([resolved])
  @@map("alerts")
}

// ─────────────────────────────────────────────
// Classification — waste image classification result
// ─────────────────────────────────────────────
enum WasteLabel {
  organik
  anorganik
  b3
  unknown
}

model Classification {
  id    String @id @default(cuid())
  binId String
  bin   Bin    @relation(fields: [binId], references: [id], onDelete: Cascade)

  label      WasteLabel
  confidence Float
  rawResult  Json? // Full classifier response (all detections)

  createdAt DateTime @default(now())

  @@index([binId])
  @@index([createdAt])
  @@map("classifications")
}

// ─────────────────────────────────────────────
// User — admin and field officers
// ─────────────────────────────────────────────
enum UserRole {
  ADMIN
  PETUGAS
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        UserRole @default(PETUGAS)
  deviceToken String? // Firebase FCM token

  // Relationships
  areaId String? // If PETUGAS, which area they handle. If null, they might have no area assigned yet.
  area   Area?   @relation(fields: [areaId], references: [id])

  pickups   Pickup[] // Pickups completed by this officer
  schedules Schedule[] // Jadwal tugas yang ditetapkan admin untuk petugas ini

  createdAt DateTime @default(now())

  @@map("users")
}

// ─────────────────────────────────────────────
// Area — coverage area for bins and field officers
// ─────────────────────────────────────────────
model Area {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  bins      Bin[]
  users     User[]
  schedules Schedule[]

  @@map("areas")
}

// ─────────────────────────────────────────────
// Pickup — proof that an officer collected a bin
// Checkpoint hybrid: tombol "Selesai" (siapa/kapan/GPS) + konfirmasi sensor
// ─────────────────────────────────────────────
enum PickupStatus {
  MENUNGGU_SENSOR // Petugas sudah tekan "Selesai", menunggu sensor konfirmasi bin kosong
  SELESAI // Sensor sudah konfirmasi volume/berat turun — pickup terverifikasi
}

model Pickup {
  id String @id @default(cuid())

  binId String
  bin   Bin    @relation(fields: [binId], references: [id], onDelete: Cascade)

  petugasId String
  petugas   User   @relation(fields: [petugasId], references: [id])

  areaId  String? // Snapshot area bin saat pickup (untuk scoping & histori)
  alertId String? // Alert "penuh" yang memicu pickup (jika ada)

  status PickupStatus @default(MENUNGGU_SENSOR)

  // Checkpoint dari tombol "Selesai"
  completedAt  DateTime @default(now())
  completedLat Float? // GPS petugas saat menekan Selesai (dicatat, tidak divalidasi jarak)
  completedLng Float?

  // Checkpoint dari sensor
  sensorConfirmedAt DateTime?

  createdAt DateTime @default(now())

  @@index([binId])
  @@index([petugasId])
  @@index([status])
  @@map("pickups")
}

// ─────────────────────────────────────────────
// Schedule — jadwal tugas yang ditetapkan admin per petugas
// ─────────────────────────────────────────────
enum ScheduleStatus {
  PENDING // Belum dikerjakan
  PROSES // Sedang dikerjakan
  SELESAI // Selesai
}

model Schedule {
  id String @id @default(cuid())

  petugasId String
  petugas   User   @relation(fields: [petugasId], references: [id], onDelete: Cascade)

  areaId String? // Snapshot area petugas saat jadwal dibuat
  area   Area?   @relation(fields: [areaId], references: [id])

  date      DateTime // Tanggal jadwal
  startTime String // Jam mulai, mis. "08.00"
  endTime   String // Jam selesai, mis. "10.00"
  truck     String? // Nomor truk/rute, mis. "TRK-01"
  binTarget Int     @default(0) // Target jumlah bin
  note      String? // Catatan opsional

  status ScheduleStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([petugasId])
  @@index([date])
  @@map("schedules")
}
